OPENAI_API_KEY=sk-...
HD_API_KEY=your_humandesignapi_nl_developer_key

# HR Talent Map v2 core layers background spike (Stage 4.6 / 4.6.2)
# HR_TALENT_MAP_V2_BACKGROUND_CORE_LAYERS_ENABLED=true
# HR_TALENT_MAP_V2_CORE_LAYERS_RUN_MODE=layer
# OPENAI_RESPONSES_MODEL_SMOKE=gpt-5-nano
# OPENAI_RESPONSES_MODEL_LAYER=gpt-5-nano
# OPENAI_RESPONSES_MODEL_REASONING=gpt-5-nano

# Optional output token ceilings for HR Talent Map v2 core layers spike
# Defaults: smoke=3500, layer=4500
# HR_TALENT_MAP_V2_CORE_LAYER_MAX_OUTPUT_TOKENS_SMOKE=3500
# HR_TALENT_MAP_V2_CORE_LAYER_MAX_OUTPUT_TOKENS_LAYER=4500

# GPT-5.x Responses API tuning (Stage 4.6.2 — cost guard defaults)
# HR_TALENT_MAP_V2_CORE_LAYER_REASONING_EFFORT_SMOKE=minimal
# HR_TALENT_MAP_V2_CORE_LAYER_REASONING_EFFORT_LAYER=minimal
# HR_TALENT_MAP_V2_CORE_LAYER_VERBOSITY_SMOKE=low
# HR_TALENT_MAP_V2_CORE_LAYER_VERBOSITY_LAYER=low
# HR_TALENT_MAP_V2_CORE_LAYER_PROMPT_CACHE_KEY=hr_talent_map_v2_core_layers_background_0_4
# HR_TALENT_MAP_V2_CORE_LAYER_PROMPT_CACHE_RETENTION=24h

# Legacy env (do not remove from Netlify yet; code paths may still exist):
# HR_TALENT_MAP_V2_BACKGROUND_WORK_FORMAT_ENABLED — Stage 4.2 single-layer work_format spike
# OPENAI_RESPONSES_MODEL — legacy work_format spike model
# HR_TALENT_MAP_V2_LIMITED_LAYERS_ENABLED — Stage 4.0 limited 3-layer generation
# VITE_ENABLE_HR_TALENT_MAP_V2_FIXTURE — old fixture preview flag (?tm_v2_fixture=1)

# Optional: only if switching to POST /v2/charts with "location" field
# HD_GEOCODE_KEY=your_humandesignapi_nl_geocode_key
